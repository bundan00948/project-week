                    "average-delay-label": "Average Delay",                           
                    "crossing-duration": "Estimated Crossing Duration",                           
                    "friendship-bridge": "Friendship Bridge",                           
                    "sai-van-bridge": "Sai Van Bridge",                           
                    "horta-costa": "Avenida de Horta e Costa",                           
